+#if defined(TARGET_M68K)
+        /* M68K: Handle RTE (Return from Exception) by calling QEMU's native handler.
+         * EXCP_RTE (0x100) needs special handling because m68k_interrupt_all() must
+         * be called to update PC from stack. If we don't do this here, exception_index
+         * gets cleared (line 426) before m68k_interrupt_all() is ever called, causing
+         * an infinite RTE loop with batch execution.
+         */
+        if (cpu->exception_index == 0x100) {  /* EXCP_RTE */
+            CPUM68KState *env = &(M68K_CPU(uc->cpu)->env);
+            m68k_interrupt_all(env, 0);  /* is_hw=0 for software exception */
+            cpu->exception_index = -1;
+            *ret = EXCP_INTERRUPT;
+            return false;
+        }
 #endif
         // Unicorn: call registered interrupt callbacks
         catched = false;
